export default function CollegeGolfAnalytics() {
  const [metric, setMetric] = useState(METRICS[0].key);
  const [team1, setTeam1] = useState(TEAMS[48]); // Vanderbilt
  const [team2, setTeam2] = useState(TEAMS[33]); // Oklahoma State
  const [analysis, setAnalysis] = useState("");
  const [loading, setLoading] = useState(false);
  const [indexChart, setIndexChart] = useState([]);
  const [cards, setCards] = useState([]);
  const [conf1, setConf1] = useState("");
  const [conf2, setConf2] = useState("");
  const abortRef = useRef(null);

  const isScoringMetric = metric === "scoring";

  const runAnalysis = async () => {
    if (team1 === team2) {
      setAnalysis("Please select two different programs to compare.");
      return;
    }

    if (abortRef.current) abortRef.current.abort();
    const controller = new AbortController();
    abortRef.current = controller;

    setLoading(true);
    setAnalysis("");
    setIndexChart([]);
    setCards([]);
    setConf1("");
    setConf2("");

    const metricLabel = METRICS.find(m => m.key === metric)?.label;
    const score1 = SCORING_AVERAGES[team1];
    const score2 = SCORING_AVERAGES[team2];

    const scoringContext = isScoringMetric
      ? `Use these actual 2024-25 scoring averages: ${team1} = ${score1} strokes/round, ${team2} = ${score2} strokes/round. National D1 average ≈ 288.0.`
      : "";

    const prompt = `You are an expert NCAA college golf analyst. Compare the men's golf programs of ${team1} and ${team2} on the metric: "${metricLabel}" for the 2024-25 season. ${scoringContext}

Respond ONLY with a valid JSON object — no markdown, no backticks, no extra text:
{
  "conf1": "conference name for ${team1}",
  "conf2": "conference name for ${team2}",
  "summary": "2-3 sentence expert analysis comparing these two programs on this metric, using real program history and data",
  "insight": "1 actionable insight for an athletic department or analyst evaluating these programs",
  "cards": [
    {"label": "relevant stat", "value": "realistic value", "sub": "brief context"},
    {"label": "relevant stat", "value": "realistic value", "sub": "brief context"},
    {"label": "relevant stat", "value": "realistic value", "sub": "brief context"},
    {"label": "relevant stat", "value": "realistic value", "sub": "brief context"}
  ],
  "chart": [
    {"label": "${team1}", "value": 85},
    {"label": "${team2}", "value": 78},
    {"label": "National Average", "value": 62},
    {"label": "Top Program", "value": 96}
  ]
}

${isScoringMetric
  ? "For the chart field, return 1–100 index values for visual comparison. Cards must include the real stroke average, stroke differential vs national average, and national rank estimate."
  : "Chart values must be integers 1–100. Cards should use real sport-specific stats like recruiting rank, NCAA appearances, or win percentage."
}`;

    try {
      const response = await fetch("https://api.anthropic.com/v1/messages", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          model: "claude-sonnet-4-20250514",
          max_tokens: 1000,
          messages: [{ role: "user", content: prompt }],
        }),
        signal: controller.signal,
      });

      const data = await response.json();
      const text = data.content?.map(b => b.text || "").join("") || "";

      try {
        const clean = text.replace(/```json|```/g, "").trim();
        const parsed = JSON.parse(clean);
        setConf1(parsed.conf1 || "");
        setConf2(parsed.conf2 || "");
        setCards(parsed.cards || []);
        if (!isScoringMetric) setIndexChart(parsed.chart || []);
        setAnalysis(
          (parsed.summary || "") +
          (parsed.insight ? `\n\nKey insight: ${parsed.insight}` : "")
        );
      } catch {
        setAnalysis(text);
      }
    } catch (e) {
      if (e.name !== "AbortError") setAnalysis("Error fetching analysis. Please try again.");
    } finally {
      setLoading(false);
    }
  };

  const score1 = SCORING_AVERAGES[team1];
  const score2 = SCORING_AVERAGES[team2];

  return (
    <div style={{ padding: "1.5rem 0", fontFamily: "var(--font-sans)" }}>

      {/* Header */}
      <div style={{ marginBottom: "1.5rem" }}>
        <h2 style={{ fontSize: 18, fontWeight: 500, margin: "0 0 4px", color: "var(--color-text-primary)" }}>
          ⛳ College golf analytics
        </h2>
        <p style={{ fontSize: 13, color: "var(--color-text-secondary)", margin: 0 }}>
          AI-powered NCAA men's golf program comparison — 50 programs
        </p>
      </div>

      {/* Program selectors */}
      <div style={{ display: "grid", gridTemplateColumns: "1fr 1fr", gap: 12, marginBottom: "1rem" }}>
        <div>
          <label style={{ fontSize: 12, color: "var(--color-text-secondary)", display: "block", marginBottom: 4 }}>Program A</label>
          <select value={team1} onChange={e => setTeam1(e.target.value)} style={{ width: "100%" }}>
            {TEAMS.map(t => <option key={t}>{t}</option>)}
          </select>
          {conf1 && <span style={{ fontSize: 11, color: "var(--color-text-secondary)", marginTop: 4, display: "block" }}>{conf1}</span>}
        </div>
        <div>
          <label style={{ fontSize: 12, color: "var(--color-text-secondary)", display: "block", marginBottom: 4 }}>Program B</label>
          <select value={team2} onChange={e => setTeam2(e.target.value)} style={{ width: "100%" }}>
            {TEAMS.map(t => <option key={t}>{t}</option>)}
          </select>
          {conf2 && <span style={{ fontSize: 11, color: "var(--color-text-secondary)", marginTop: 4, display: "block" }}>{conf2}</span>}
        </div>
      </div>

      {/* Scoring preview strip — visible any time scoring metric is active */}
      {isScoringMetric && (
        <div style={{
          display: "grid",
          gridTemplateColumns: "1fr 1fr",
          gap: 12,
          marginBottom: "1rem",
          padding: "0.75rem 1rem",
          background: "var(--color-background-secondary)",
          borderRadius: "var(--border-radius-md)",
        }}>
          <div>
            <span style={{ fontSize: 11, color: "var(--color-text-secondary)", display: "block" }}>{team1}</span>
            <span style={{ fontSize: 20, fontWeight: 500, color: "#378ADD" }}>{score1.toFixed(1)}</span>
            <span style={{ fontSize: 11, color: "var(--color-text-secondary)" }}> strokes / round</span>
          </div>
          <div>
            <span style={{ fontSize: 11, color: "var(--color-text-secondary)", display: "block" }}>{team2}</span>
            <span style={{ fontSize: 20, fontWeight: 500, color: "#1D9E75" }}>{score2.toFixed(1)}</span>
            <span style={{ fontSize: 11, color: "var(--color-text-secondary)" }}> strokes / round</span>
          </div>
        </div>
      )}

      {/* Metric selector */}
      <div style={{ marginBottom: "1rem" }}>
        <label style={{ fontSize: 12, color: "var(--color-text-secondary)", display: "block", marginBottom: 4 }}>Analysis focus</label>
        <select value={metric} onChange={e => setMetric(e.target.value)} style={{ width: "100%" }}>
          {METRICS.map(m => <option key={m.key} value={m.key}>{m.label}</option>)}
        </select>
      </div>

      {/* Run button */}
      <button
        onClick={runAnalysis}
        disabled={loading}
        style={{
          width: "100%",
          padding: "10px",
          borderRadius: "var(--border-radius-md)",
          border: "0.5px solid var(--color-border-secondary)",
          background: loading ? "var(--color-background-secondary)" : "var(--color-background-primary)",
          color: "var(--color-text-primary)",
          fontSize: 14,
          fontWeight: 500,
          cursor: loading ? "not-allowed" : "pointer",
          marginBottom: "1.5rem",
        }}
      >
        {loading ? "Analyzing..." : "Run analysis ↗"}
      </button>

      {/* Metric cards */}
      {(cards.length > 0 || loading) && (
        <div style={{ display: "grid", gridTemplateColumns: "repeat(2, 1fr)", gap: 12, marginBottom: "1.5rem" }}>
          {cards.length > 0
            ? cards.map((c, i) => (
                <MetricCard key={i} label={c.label} value={c.value} sub={c.sub} accent={i % 2 === 0 ? "#378ADD" : "#1D9E75"} />
              ))
            : [0, 1, 2, 3].map(i => <MetricCard key={i} label="Loading..." value="—" />)}
        </div>
      )}

      {/* Chart */}
      {(isScoringMetric ? (analysis || loading) : indexChart.length > 0) && (
        <div style={{
          background: "var(--color-background-primary)",
          border: "0.5px solid var(--color-border-tertiary)",
          borderRadius: "var(--border-radius-lg)",
          padding: "1rem 1.25rem",
          marginBottom: "1.5rem",
        }}>
          <p style={{ fontSize: 13, fontWeight: 500, margin: "0 0 1rem", color: "var(--color-text-secondary)" }}>
            {isScoringMetric
              ? "Team scoring average — strokes per round (lower is better)"
              : `Comparative index — ${METRICS.find(m => m.key === metric)?.label}`}
          </p>
          {isScoringMetric
            ? <ScoringChart team1={team1} score1={score1} team2={team2} score2={score2} />
            : <IndexChart data={indexChart} />}
        </div>
      )}

      {/* AI analysis */}
      {(analysis || loading) && (
        <div style={{
          background: "var(--color-background-primary)",
          border: "0.5px solid var(--color-border-tertiary)",
          borderRadius: "var(--border-radius-lg)",
          padding: "1rem 1.25rem",
          marginBottom: "1.5rem",
        }}>
          <p style={{ fontSize: 13, fontWeight: 500, margin: "0 0 8px", color: "var(--color-text-secondary)" }}>
            ⛳ Analysis — {team1} vs {team2}
          </p>
          <div style={{ fontSize: 14, lineHeight: 1.7, color: "var(--color-text-primary)", whiteSpace: "pre-wrap", minHeight: 80 }}>
            {loading && !analysis
              ? <span style={{ color: "var(--color-text-secondary)" }}>Analyzing programs...</span>
              : analysis}
            {loading && analysis && <span style={{ opacity: 0.5 }}>▍</span>}
          </div>
        </div>
      )}

      {/* Empty state */}
      {!analysis && !loading && (
        <div style={{
          textAlign: "center",
          padding: "2rem",
          color: "var(--color-text-secondary)",
          fontSize: 13,
          border: "0.5px dashed var(--color-border-tertiary)",
          borderRadius: "var(--border-radius-lg)",
          marginBottom: "1.5rem",
        }}>
          Select two programs and an analysis focus — then click Run analysis
        </div>
      )}

      {/* Sources */}
      <div style={{
        borderTop: "0.5px solid var(--color-border-tertiary)",
        paddingTop: "1rem",
      }}>
        <p style={{ fontSize: 12, fontWeight: 500, color: "var(--color-text-secondary)", margin: "0 0 8px" }}>
          Data sources
        </p>
        <div style={{ display: "flex", flexDirection: "column", gap: 6 }}>
          {SOURCES.map((s, i) => (
            <a
              key={i}
              href={s.url}
              target="_blank"
              rel="noopener noreferrer"
              style={{ fontSize: 12, color: "#378ADD", textDecoration: "none", display: "flex", alignItems: "center", gap: 6 }}
            >
              <span style={{ opacity: 0.5, fontSize: 10 }}>↗</span>
              {s.label}
            </a>
          ))}
        </div>
      </div>

    </div>
  );
}
