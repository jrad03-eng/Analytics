function MetricCard({ label, value, sub, accent }) {
  return (
    <div style={{
      background: "var(--color-background-secondary)",
      borderRadius: "var(--border-radius-md)",
      padding: "1rem",
      display: "flex",
      flexDirection: "column",
      gap: 4,
    }}>
      <span style={{ fontSize: 12, color: "var(--color-text-secondary)" }}>{label}</span>
      <span style={{ fontSize: 22, fontWeight: 500, color: accent || "var(--color-text-primary)" }}>{value}</span>
      {sub && <span style={{ fontSize: 12, color: "var(--color-text-secondary)" }}>{sub}</span>}
    </div>
  );
}

// Inverted bar chart — lower stroke score = longer bar
function ScoringChart({ team1, score1, team2, score2 }) {
  const nationalAvg = 288.0;
  const topBenchmark = 282.8;

  const entries = [
    { label: team1, score: score1, color: "#378ADD" },
    { label: team2, score: score2, color: "#1D9E75" },
    { label: "National average", score: nationalAvg, color: "#888780" },
    { label: "Top program benchmark", score: topBenchmark, color: "#BA7517" },
  ];

  const worst = Math.max(...entries.map(e => e.score)) + 2;
  const best = Math.min(...entries.map(e => e.score)) - 1;
  const range = worst - best;

  return (
    <div>
      <p style={{ fontSize: 12, color: "var(--color-text-secondary)", margin: "0 0 12px", fontStyle: "italic" }}>
        Longer bar = better. Lower strokes per round wins in golf.
      </p>
      <div style={{ display: "flex", flexDirection: "column", gap: 10 }}>
        {entries.map((e, i) => {
          const pct = Math.round(((worst - e.score) / range) * 100);
          return (
            <div key={i} style={{ display: "flex", alignItems: "center", gap: 8 }}>
              <span style={{ fontSize: 12, color: "var(--color-text-secondary)", minWidth: 190, textAlign: "right", lineHeight: 1.3 }}>
                {e.label}
              </span>
              <div style={{ flex: 1, background: "var(--color-background-secondary)", borderRadius: 4, height: 22, overflow: "hidden" }}>
                <div style={{
                  width: `${pct}%`,
                  height: "100%",
                  background: e.color,
                  borderRadius: 4,
                  transition: "width 0.6s ease",
                }} />
              </div>
              <span style={{ fontSize: 12, fontWeight: 500, minWidth: 42, textAlign: "right" }}>
                {e.score.toFixed(1)}
              </span>
            </div>
          );
        })}
      </div>
      <div style={{ display: "flex", flexWrap: "wrap", gap: 12, marginTop: 12, fontSize: 11, color: "var(--color-text-secondary)" }}>
        {entries.map(e => (
          <span key={e.label} style={{ display: "flex", alignItems: "center", gap: 4 }}>
            <span style={{ width: 10, height: 10, borderRadius: 2, background: e.color, display: "inline-block", flexShrink: 0 }} />
            {e.label}
          </span>
        ))}
      </div>
    </div>
  );
}

// Standard index chart for non-scoring metrics
function IndexChart({ data }) {
  if (!data || data.length === 0) return null;
  const max = Math.max(...data.map(d => d.value));
  const palette = ["#378ADD", "#1D9E75", "#888780", "#BA7517"];
  return (
    <div style={{ display: "flex", flexDirection: "column", gap: 10 }}>
      {data.map((d, i) => (
        <div key={i} style={{ display: "flex", alignItems: "center", gap: 8 }}>
          <span style={{ fontSize: 12, color: "var(--color-text-secondary)", minWidth: 190, textAlign: "right", lineHeight: 1.3 }}>
            {d.label}
          </span>
          <div style={{ flex: 1, background: "var(--color-background-secondary)", borderRadius: 4, height: 22, overflow: "hidden" }}>
            <div style={{
              width: `${Math.round((d.value / max) * 100)}%`,
              height: "100%",
              background: palette[i] || "#378ADD",
              borderRadius: 4,
              transition: "width 0.6s ease",
            }} />
          </div>
          <span style={{ fontSize: 12, fontWeight: 500, minWidth: 32, textAlign: "right" }}>{d.value}</span>
        </div>
      ))}
      <div style={{ display: "flex", flexWrap: "wrap", gap: 12, marginTop: 4, fontSize: 11, color: "var(--color-text-secondary)" }}>
        {data.map((d, i) => (
          <span key={d.label} style={{ display: "flex", alignItems: "center", gap: 4 }}>
            <span style={{ width: 10, height: 10, borderRadius: 2, background: palette[i], display: "inline-block", flexShrink: 0 }} />
            {d.label}
          </span>
        ))}
      </div>
    </div>
  );
}

